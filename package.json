{
  "name": "@chorus-pay/connector-sdk",
  "version": "1.0.1",
  "description": "SDK officiel pour créer des connecteurs Chorus Pay (ERP, boutiques)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["chorus-pay", "connector", "sdk", "erp", "facturation"],
  "repository": {
    "type": "git",
    "url": "https://github.com/tim-tiret/chorus-pay-connector-sdk.git"
  },
  "homepage": "https://choruspay.fr/doc/connecteurs",
  "peerDependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "zod": "^3.25.0"
  }
}
